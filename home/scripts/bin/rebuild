#!/usr/bin/env bash

set -e
pushd ~/.dotfiles > /dev/null
nvim .

nix run nixpkgs#alejandra .

# Early return if nothing changed
if git diff --quiet .; then
    echo "No changes detected, exiting."
    popd > /dev/null
    exit 0
fi

nix flake update
batdiff .
git add . 

nh os test .
popd > /dev/null

# Send desktop notification if `mako` is installed
if type mako > /dev/null 
then
    notify-send "NixOS Rebuilt OK!"
fi
